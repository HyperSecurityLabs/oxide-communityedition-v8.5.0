#!/bin/bash
# OXIDE CE — Terminal Launcher
# Author: KhaninKali @ HyperSecurity

export LD_LIBRARY_PATH="/usr/lib:/usr/lib/oxide:$LD_LIBRARY_PATH"

if [ $# -eq 0 ]; then
    /usr/bin/oxide-ce-bin --help 2>&1
    echo ""
    echo "  ──────────────────────────────────────────────"
else
    /usr/bin/oxide-ce-bin "$@"
fi

exec $SHELL
